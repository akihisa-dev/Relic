{
  "name": "relic",
  "version": "0.56.7",
  "description": "Relic is a local app that extends Markdown files with editing, search, browsing, visualization, and export while keeping the information as Markdown.",
  "license": "AGPL-3.0-or-later",
  "main": ".vite/build/main.js",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=22 <27"
  },
  "scripts": {
    "preinstall": "node scripts/runtime-policy.mjs",
    "start": "electron-forge start",
    "start:mac": "electron-forge start",
    "start:isolated": "node scripts/start-development-app.mjs",
    "typecheck": "tsc --noEmit",
    "runtime:check": "node scripts/runtime-policy.mjs",
    "verify": "pnpm runtime:check && pnpm typecheck && pnpm test && pnpm licenses:check",
    "verify:full": "pnpm runtime:check && pnpm typecheck && pnpm test:coverage && pnpm architecture:check && pnpm docs:index:check && pnpm ci:workflows:check && pnpm skills:check && pnpm skills:audit:self-test && pnpm licenses:check",
    "verify:ci": "pnpm verify:full && pnpm renderer:production:check && pnpm security:audit",
    "version:next": "node scripts/version-policy.mjs next",
    "version:check": "node scripts/version-policy.mjs check-range",
    "version:check-staged": "node scripts/version-policy.mjs check-staged",
    "docs:index:check": "node scripts/docs-index.mjs --check",
    "docs:tree": "node scripts/docs-index.mjs --tree",
    "ci:workflows:check": "node scripts/check-github-workflows.mjs",
    "committed-diff:check": "node scripts/check-committed-diff.mjs",
    "skills:check": "python3 ../.agents/skills/relic-audit-skills/scripts/collect_skill_evidence.py --workspace .. --root .agents/skills --format summary --fail-on-issues",
    "skills:audit:self-test": "python3 ../.agents/skills/relic-audit-skills/scripts/collect_skill_evidence.py --self-test && python3 ../.agents/skills/relic-audit-skills/scripts/validate_routing_ledger.py --self-test",
    "skills:routing:audit": "python3 ../.agents/skills/relic-audit-skills/scripts/validate_routing_ledger.py --workspace ..",
    "package": "node scripts/run-forge-build.mjs package",
    "package:mac": "node scripts/run-forge-build.mjs package",
    "make": "node scripts/run-forge-build.mjs make",
    "make:mac": "node scripts/run-forge-build.mjs make",
    "test": "vitest run",
    "test:node": "vitest run --project node",
    "test:renderer": "vitest run --project renderer",
    "test:coverage": "vitest run --coverage",
    "test:inventory": "node scripts/test-inventory.mjs",
    "smoke:electron": "node scripts/electron-smoke.mjs development",
    "smoke:package": "node scripts/electron-smoke.mjs package",
    "test:mac": "vitest run",
    "test:watch": "vitest",
    "architecture:check": "node scripts/architecture-check.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "licenses:check": "node scripts/generate-third-party-notices.mjs --check && node scripts/generate-sbom.mjs --check",
    "licenses:generate": "node scripts/generate-third-party-notices.mjs && node scripts/generate-sbom.mjs",
    "security:audit": "pnpm audit --prod --audit-level high",
    "sbom:generate": "node scripts/generate-sbom.mjs",
    "renderer:production:check": "node scripts/renderer-production-check.mjs",
    "source:size": "node scripts/source-size-report.mjs",
    "source:size:baseline": "node scripts/source-size-report.mjs --write-baseline scripts/baselines/source-lines.json",
    "workspace:generate-large": "node scripts/generate-large-workspace.mjs",
    "performance:workspace": "node --expose-gc scripts/workspace-performance-report.mjs",
    "performance:workspace:large": "node --expose-gc scripts/workspace-performance-report.mjs --files 10000 --directories 100",
    "performance:sphere": "node scripts/sphere-performance-report.mjs",
    "clean:out": "node scripts/clean-out.mjs",
    "check:mac:safe": "node scripts/check-package-artifacts.mjs",
    "build:mac:safe": "node scripts/build-platform.mjs"
  },
  "dependencies": {
    "3d-force-graph": "^1.80.0",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@lezer/markdown": "^1.6.3",
    "@terrastruct/d2": "^0.1.33",
    "d3-force": "^3.0.0",
    "dompurify": "^3.4.11",
    "highlight.js": "^11.11.1",
    "js-yaml": "^5.2.1",
    "katex": "^0.17.0",
    "marked": "^18.0.3",
    "marked-footnote": "^1.4.0",
    "mermaid": "^11.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.185.1",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/asar": "^3.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/d3-force": "^3.0.10",
    "@types/katex": "^0.16.8",
    "@types/node": "^26.1.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "^43.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
