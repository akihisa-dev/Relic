{
  "name": "relic",
  "version": "0.1.218",
  "description": "Relic is a local app that extends Markdown files with editing, search, browsing, visualization, and export while keeping the information as Markdown.",
  "main": ".vite/build/main.js",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "start": "electron-forge start",
    "start:mac": "electron-forge start",
    "start:win": "electron-forge start",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm typecheck && pnpm test",
    "verify:full": "pnpm verify && git -C .. diff --check",
    "package": "electron-forge package",
    "package:mac": "electron-forge package --platform darwin",
    "package:win": "electron-forge package --platform win32 --arch x64",
    "make": "electron-forge make",
    "make:mac": "electron-forge make --platform darwin",
    "make:win": "electron-forge make --platform win32 --arch x64",
    "test": "vitest run",
    "test:mac": "vitest run",
    "test:win": "vitest run",
    "test:watch": "vitest",
    "generate:icons": "node scripts/generate-icons.mjs",
    "clean:out": "node scripts/clean-out.mjs",
    "check:mac:safe": "node scripts/check-package-artifacts.mjs darwin",
    "check:win:safe": "node scripts/check-package-artifacts.mjs win32",
    "build:mac:safe": "pnpm clean:out && pnpm package:mac && pnpm check:mac:safe",
    "build:win:safe": "pnpm clean:out && pnpm package:win && pnpm check:win:safe"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "fs-xattr",
      "macos-alias"
    ]
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@terrastruct/d2": "^0.1.33",
    "dompurify": "^3.4.2",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.45",
    "marked": "^18.0.3",
    "marked-footnote": "^1.4.0",
    "mermaid": "^11.15.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-dmg": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-vite": "^7.8.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/dompurify": "^3.2.0",
    "@types/js-yaml": "^4.0.9",
    "@types/katex": "^0.16.8",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.1.3",
    "electron": "^36.2.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vitest": "^3.1.3"
  }
}
