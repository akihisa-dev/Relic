#!/bin/sh
set -eu

blocked=0

staged_files=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$staged_files" ]; then
  exit 0
fi

is_text_file() {
  case "$1" in
    *.png|*.jpg|*.jpeg|*.gif|*.webp|*.ico|*.icns|*.pdf|*.zip|*.dmg|*.exe|*.dll|*.node)
      return 1
      ;;
  esac
  return 0
}

is_guard_file() {
  case "$1" in
    .githooks/pre-commit|.githooks/pre-push)
      return 0
      ;;
  esac
  return 1
}

check_name() {
  path="$1"
  base=$(basename "$path")

  case "$base" in
    .env|.env.*|*.env|*.env.*)
      case "$base" in
        .env.example|*.example)
          return 0
          ;;
      esac
      echo "Blocked local env file: $path" >&2
      return 1
      ;;
    *client-secret*|*credentials*|*secret*|*token*|*.keychain|*.keychain-db|*keychain-export*)
      echo "Blocked credential-bearing filename: $path" >&2
      return 1
      ;;
  esac

  return 0
}

check_content() {
  path="$1"

  if is_guard_file "$path"; then
    return 0
  fi

  if ! is_text_file "$path"; then
    return 0
  fi

  content=$(git show ":$path" 2>/dev/null || true)

  if [ -z "$content" ]; then
    return 0
  fi

  if printf '%s\n' "$content" | grep -Eiq 'Authorization:[[:space:]]*Bearer[[:space:]]+[A-Za-z0-9_./+=:@-]{16,}'; then
    echo "Blocked HTTP Bearer credential in: $path" >&2
    return 1
  fi

  if printf '%s\n' "$content" | grep -Eiq 'Authorization:[[:space:]]*Basic[[:space:]]+[A-Za-z0-9+/=]{16,}'; then
    echo "Blocked HTTP Basic credential in: $path" >&2
    return 1
  fi

  if printf '%s\n' "$content" | grep -Eiq '(^|[^A-Za-z0-9_])(ghp_|gho_|ghu_|ghs_|ghr_|github_pat_[A-Za-z0-9_])'; then
    echo "Blocked GitHub token pattern in: $path" >&2
    return 1
  fi

  if printf '%s\n' "$content" | grep -Eiq 'BEGIN (RSA |DSA |EC |OPENSSH |PGP )?PRIVATE KEY|BEGIN PRIVATE KEY|BEGIN OPENSSH PRIVATE KEY'; then
    echo "Blocked private key material in: $path" >&2
    return 1
  fi

  if printf '%s\n' "$content" | grep -Eiq '(^|[^A-Za-z0-9_])(access_token|client_secret|refresh_token|id_token|private_key|_authToken|NPM_TOKEN)[[:space:]]*[:=][[:space:]]*["'\'']?[A-Za-z0-9_./+=:@-]{16,}'; then
    echo "Blocked credential assignment pattern in: $path" >&2
    return 1
  fi

  if printf '%s\n' "$content" | grep -Eiq '(npm_[A-Za-z0-9]{36,}|xox[baprs]-[A-Za-z0-9-]{20,}|https://hooks\.slack\.com/services/[A-Za-z0-9/_-]{20,}|sk_live_[A-Za-z0-9]{16,}|rk_live_[A-Za-z0-9]{16,})'; then
    echo "Blocked supported provider token pattern in: $path" >&2
    return 1
  fi

  if printf '%s\n' "$content" | grep -Eiq '(mongodb(\+srv)?|mysql|postgres(ql)?):\/\/[^[:space:]@:/]+:[^[:space:]@/]+@'; then
    echo "Blocked database connection string with credentials in: $path" >&2
    return 1
  fi

  if printf '%s\n' "$content" | grep -Eq 'AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}'; then
    echo "Blocked AWS access key identifier in: $path" >&2
    return 1
  fi

  return 0
}

for path in $staged_files; do
  if ! check_name "$path"; then
    blocked=1
  fi

  if ! check_content "$path"; then
    blocked=1
  fi
done

if [ "$blocked" -ne 0 ]; then
  cat >&2 <<'EOF'

Commit blocked by Relic secret guard.
Do not commit OAuth tokens, client secrets, private keys, .env files, keychain exports, or local credential files.
If this is a false positive, move the value to a local ignored file or macOS Keychain, then stage again.
EOF
  exit 1
fi

exit 0
