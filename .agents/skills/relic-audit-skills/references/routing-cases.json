{
  "version": 1,
  "cases": [
    {
      "id": "issue-all-open",
      "request": "残っているOpen Issueをすべて対応してください",
      "expectedEntrySkill": "relic-issue",
      "expectedSpecialistSkills": ["relic-guard-task", "relic-change-ci", "relic-test-code", "relic-debug-packaging", "relic-audit-code-health", "relic-audit-skills", "relic-maintain-docs", "relic-commit", "relic-manage-version"],
      "forbiddenSkills": ["relic-publish-github", "relic-release"],
      "requiredDocs": ["AGENTS.md", "docs/INDEX.md", "docs/development.md"],
      "permissionMode": "local-change-no-push",
      "expectedEndState": "ローカル修正・検証・完了コミット後、pushせずIssueへ完了コメントしてcloseする",
      "misrouteImpact": "一次情報未確認、無断push、完了コミット前のIssue closeにつながる"
    },
    {
      "id": "code-health-vs-refactor",
      "request": "肥大化したrendererの単一領域を監査し、根拠のある局所改善をしてください",
      "expectedEntrySkill": "relic-audit-code-health",
      "expectedSpecialistSkills": ["relic-guard-task", "relic-test-code"],
      "forbiddenSkills": ["relic-refactor-codebase"],
      "requiredDocs": ["docs/development.md"],
      "permissionMode": "local-change",
      "expectedEndState": "単一領域の測定、局所改善、比較検証",
      "misrouteImpact": "依頼範囲を越えた包括的変更になる"
    },
    {
      "id": "task-target-mismatch",
      "request": "Relicを作業中です。添付したCI画像には別リポジトリ名が表示されていますが、調べて修正しpushしてください",
      "expectedEntrySkill": "relic-guard-task",
      "expectedSpecialistSkills": [],
      "forbiddenSkills": ["relic-change-ci", "relic-publish-github"],
      "requiredDocs": ["AGENTS.md"],
      "permissionMode": "read-only-stop-on-target-mismatch",
      "expectedEndState": "別リポジトリを作業対象へ推定せず、確認済みの不一致と必要な判断を報告して書き込まない",
      "misrouteImpact": "無関係なリポジトリの変更と無断pushにつながる"
    },
    {
      "id": "reference-first-ui",
      "request": "このコードと画像の動きをRelicの設定トグルに使いたいです。まず単独見本だけを見せてください",
      "expectedEntrySkill": "relic-change-ui",
      "expectedSpecialistSkills": ["relic-guard-task"],
      "forbiddenSkills": ["relic-commit", "relic-publish-github"],
      "requiredDocs": ["docs/design/DESIGN.md"],
      "permissionMode": "sample-only-no-product-change",
      "expectedEndState": "見本の構造と動きを保つ単独サンプルを実表示確認し、製品コードは変更しない",
      "misrouteImpact": "見本の意図を外した独自デザイン実装と不要なコミットにつながる"
    },
    {
      "id": "full-refactor",
      "request": "コードベース全体の責務、状態所有、性能、配布境界を包括的にリファクタリングしてください",
      "expectedEntrySkill": "relic-refactor-codebase",
      "expectedSpecialistSkills": ["relic-guard-task", "relic-audit-code-health", "relic-test-code", "relic-maintain-docs"],
      "forbiddenSkills": [],
      "requiredDocs": ["docs/INDEX.md", "docs/development.md"],
      "permissionMode": "local-change",
      "expectedEndState": "互換性を維持した横断改善と全体検証",
      "misrouteImpact": "局所最適化だけで包括的完了条件を満たさない"
    },
    {
      "id": "ui-localization-navigation",
      "request": "左レールの表示名、配置、キーボード移動を日英両方で変更してください",
      "expectedEntrySkill": "relic-change-navigation",
      "expectedSpecialistSkills": ["relic-guard-task", "relic-change-ui", "relic-change-localization", "relic-test-development-app", "relic-test-code"],
      "forbiddenSkills": [],
      "requiredDocs": ["docs/design/DESIGN.md", "docs/project/terms.md"],
      "permissionMode": "local-change-and-isolated-gui",
      "expectedEndState": "状態遷移、見た目、翻訳、実画面が同期する",
      "misrouteImpact": "翻訳漏れ、遷移回帰、既存アプリ誤操作につながる"
    },
    {
      "id": "workspace-file-settings",
      "request": "ワークスペース監視復旧とピン留め設定の保存を修正してください",
      "expectedEntrySkill": "relic-change-workspace-files",
      "expectedSpecialistSkills": ["relic-guard-task", "relic-change-settings", "relic-change-electron-boundaries", "relic-test-code"],
      "forbiddenSkills": ["relic-test-development-app"],
      "requiredDocs": ["docs/engineering/file-access-boundaries.md", "docs/development.md"],
      "permissionMode": "local-change",
      "expectedEndState": "境界保護、保存互換、監視復旧を自動テストで確認する",
      "misrouteImpact": "ユーザーファイルまたは設定を壊す"
    },
    {
      "id": "markdown-stack",
      "request": "frontmatter付きMarkdownへ画像を追加し、編集・プレビュー・PDF出力まで整合してください",
      "expectedEntrySkill": "relic-change-markdown-editor",
      "expectedSpecialistSkills": ["relic-guard-task", "relic-change-frontmatter", "relic-change-attachments", "relic-change-markdown-output", "relic-change-electron-boundaries", "relic-test-code"],
      "forbiddenSkills": [],
      "requiredDocs": ["docs/INDEX.md"],
      "permissionMode": "local-change",
      "expectedEndState": "Markdown正本を保った編集・添付・出力契約が成立する",
      "misrouteImpact": "YAML、添付、安全な出力のいずれかが欠落する"
    },
    {
      "id": "derived-views",
      "request": "リンク索引を更新し、グラフとクロニクルのCanvas表示へ反映してください",
      "expectedEntrySkill": "relic-change-links-index",
      "expectedSpecialistSkills": ["relic-guard-task", "relic-change-graph", "relic-change-chronicle", "relic-test-code"],
      "forbiddenSkills": ["relic-change-search-replace"],
      "requiredDocs": ["docs/engineering/architecture.md"],
      "permissionMode": "local-change",
      "expectedEndState": "共有索引と2つのconsumerが同期する",
      "misrouteImpact": "派生データの二重実装や不整合になる"
    },
    {
      "id": "search-and-tools",
      "request": "全文検索結果を安全に一括置換し、タグ別索引ファイルも生成してください",
      "expectedEntrySkill": "relic-change-search-replace",
      "expectedSpecialistSkills": ["relic-guard-task", "relic-change-tools", "relic-change-workspace-files", "relic-test-code"],
      "forbiddenSkills": [],
      "requiredDocs": ["docs/features/search.md"],
      "permissionMode": "local-change",
      "expectedEndState": "競合検知付き置換と非破壊の生成処理が成立する",
      "misrouteImpact": "検索結果競合や入力ファイル破壊につながる"
    },
    {
      "id": "ci-vs-publish",
      "request": "main pushのGitHub Actions検証を変更してください。pushはしないでください",
      "expectedEntrySkill": "relic-change-ci",
      "expectedSpecialistSkills": ["relic-guard-task", "relic-test-code", "relic-maintain-docs"],
      "forbiddenSkills": ["relic-publish-github", "relic-release"],
      "requiredDocs": ["docs/development.md"],
      "permissionMode": "local-change-no-push",
      "expectedEndState": "安全なworkflow変更とローカル検証",
      "misrouteImpact": "依頼外の外部公開になる"
    },
    {
      "id": "ci-remote-log-diagnosis",
      "request": "GitHub Actionsの失敗を調査し、詳細ログから原因を説明してください。変更はしないでください",
      "expectedEntrySkill": "relic-change-ci",
      "expectedSpecialistSkills": [],
      "forbiddenSkills": ["relic-commit", "relic-publish-github", "relic-release"],
      "requiredDocs": ["AGENTS.md"],
      "permissionMode": "read-only-github-check-diagnosis",
      "expectedEndState": "利用可能なGitHub連携でrun・job・logを取得し、通信・認証・権限・対象不存在を分けて原因を報告する。連携で不足する場合だけ権限付きのghを補助利用する",
      "misrouteImpact": "通信制限をトークン失効と誤認し、取得可能なログを確認せず再認証を繰り返す"
    },
    {
      "id": "packaging-vs-release",
      "request": "macOS配布物のapp.asar欠落を修正してください。タグやReleaseは作らないでください",
      "expectedEntrySkill": "relic-debug-packaging",
      "expectedSpecialistSkills": ["relic-guard-task", "relic-test-code", "relic-maintain-docs"],
      "forbiddenSkills": ["relic-release", "relic-publish-github"],
      "requiredDocs": ["docs/development.md", ".github/RELEASE_CHECKLIST.md"],
      "permissionMode": "local-change-no-release",
      "expectedEndState": "macOSの安全ビルドと成果物検査",
      "misrouteImpact": "未検証成果物の公開やタグ作成につながる"
    },
    {
      "id": "dependency-update",
      "request": "ElectronとGitHub Actions参照versionを更新し、ライセンスと配布物まで確認してください",
      "expectedEntrySkill": "relic-update-dependencies",
      "expectedSpecialistSkills": ["relic-guard-task", "relic-change-ci", "relic-debug-packaging", "relic-test-code"],
      "forbiddenSkills": ["relic-release"],
      "requiredDocs": ["docs/engineering/dependency-licenses.md", "docs/development.md"],
      "permissionMode": "local-change",
      "expectedEndState": "lockfile、通知、SBOM、Renderer production build・初期読込境界、配布影響が同期する",
      "misrouteImpact": "供給網または配布互換の確認が欠落する"
    },
    {
      "id": "retire-feature",
      "request": "指定機能を保存データ互換も含めて完全に廃止してください",
      "expectedEntrySkill": "relic-retire-feature",
      "expectedSpecialistSkills": ["relic-guard-task", "relic-maintain-docs", "relic-test-code"],
      "forbiddenSkills": ["relic-refactor-codebase"],
      "requiredDocs": ["docs/INDEX.md"],
      "permissionMode": "local-change-explicit-removal",
      "expectedEndState": "入口、状態、IPC、依存、文書を横断撤去する",
      "misrouteImpact": "残存入口または保存データ破壊になる"
    },
    {
      "id": "skill-audit",
      "request": "利用可能なSkillを監査し、必要な修正を適用してください",
      "expectedEntrySkill": "relic-audit-skills",
      "expectedSpecialistSkills": ["relic-guard-task", "relic-maintain-docs"],
      "forbiddenSkills": ["relic-issue"],
      "requiredDocs": ["AGENTS.md", ".agents/skills/relic-audit-skills/references/audit-criteria.md"],
      "permissionMode": "audit-then-local-change",
      "expectedEndState": "中間レポート後に非hold候補だけ適用する",
      "misrouteImpact": "根拠なしの統合・削除または未承認変更になる"
    },
    {
      "id": "commit-and-version",
      "request": "現在の変更をバージョン規則に合わせてコミットしてください。pushはしないでください",
      "expectedEntrySkill": "relic-commit",
      "expectedSpecialistSkills": ["relic-guard-task", "relic-manage-version"],
      "forbiddenSkills": ["relic-publish-github", "relic-release"],
      "requiredDocs": ["docs/development.md"],
      "permissionMode": "local-commit-no-push",
      "expectedEndState": "検証済み差分だけを日本語Conventional Commitにする",
      "misrouteImpact": "無断push、版不整合、無関係差分混入になる"
    },
    {
      "id": "publish-vs-release",
      "request": "コミット済みの通常ブランチをpushしてDraft Pull Requestを作ってください",
      "expectedEntrySkill": "relic-publish-github",
      "expectedSpecialistSkills": ["relic-guard-task"],
      "forbiddenSkills": ["relic-release", "relic-commit"],
      "requiredDocs": ["docs/development.md"],
      "permissionMode": "explicit-push-and-draft-pr",
      "expectedEndState": "指定ブランチだけを公開しDraft PRを作成する",
      "misrouteImpact": "タグ・Releaseまたは不要な再コミットになる"
    },
    {
      "id": "release-explicit",
      "request": "確認済みコミットのタグを作り、明示したタグだけpushしてDraft Releaseを確認してください",
      "expectedEntrySkill": "relic-release",
      "expectedSpecialistSkills": ["relic-guard-task", "relic-manage-version", "relic-debug-packaging"],
      "forbiddenSkills": ["relic-publish-github"],
      "requiredDocs": [".github/RELEASE_CHECKLIST.md", "docs/development.md"],
      "permissionMode": "explicit-tag-push-no-publish",
      "expectedEndState": "タグとDraftまで進みPublishは行わない",
      "misrouteImpact": "通常ブランチ公開またはReleaseの無断Publishになる"
    }
  ]
}
